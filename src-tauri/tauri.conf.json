{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "coflux",
  "version": "0.2.6",
  "identifier": "com.karl3.coflux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "coflux",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "schemes": [
        "coflux"
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/karl3/coflux/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwMTQxQzczMDFFRUYwMUUKUldRZThPNEJjeHdVTUl6dnRCaVRRVWc3QUR4OEEycmFYcTI1dTAwb0x2b1hPZWxvQkhlTTV4aEgK"
    }
  }
}
